doctype html
html(lang=config.language)
  head
    include head.pug
  body
    //- 全局背景元素
    canvas(id="universe")

    //- 侧边栏容器
    #sidebar-container
      include sidebar.pug

    //- 主体容器
    #main-container
      //- 头部
      header#header-wrapper
        include header.pug

      //- 内容
      main#content-wrapper
        #content
          block content
        #return-top
          i.fas.fa-arrow-up(aria-hidden="true")

      //- 底部
      footer#footer-wrapper
        include footer.pug

    //- 外链重定向拦截
    script.
      (function() {
        document.addEventListener('click', function(e) {
          var link = e.target.closest('a.external-link[data-redirect]');
          if (!link) return;
          e.preventDefault();
          var url = link.getAttribute('data-redirect');
          window.location.href = '/redirect/?url=' + url;
        });
      })();
