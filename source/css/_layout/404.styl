// 404 页面样式
#page404
  display flex
  flex-direction column
  align-items center
  justify-content center
  min-height calc(100vh - 6rem)
  padding 2rem
  text-align center

  .page404-title
    font-size 6rem
    color $color-theme
    margin-bottom 1rem
    opacity 0.8

  .page404-content
    font-size 1.2rem
    color $color-text
    margin-bottom 2rem
    opacity 0.6

  .page404-countdown
    font-size 0.9rem
    color $color-text
    opacity 0.5

    #countdown-text
      font-weight bold
      color $color-theme
