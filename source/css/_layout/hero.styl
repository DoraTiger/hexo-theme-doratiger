// Hero 区域样式（pretext Canvas 排版）
#hero-wrapper
  position relative
  width 100%
  height 40vh
  min-height 260px
  max-height 420px
  overflow hidden
  display flex
  align-items center
  justify-content center

  #hero-canvas
    position absolute
    top 0
    left 0
    width 100%
    height 100%
    z-index 1

// 404 页面 Canvas 区域
.page404-canvas-wrapper
  position relative
  width 100%
  max-width 600px
  height 300px
  margin 0 auto 1.5rem

  canvas
    width 100%
    height 100%
    display block
