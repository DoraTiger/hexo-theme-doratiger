// 文章加密样式
.hexo-encrypt
  padding 2rem
  border-radius 8px
  border 1px solid $color-border
  background $color-content-background

  .hexo-encrypt-abstract
    font-size 0.95rem
    color $color-text
    opacity 0.7
    margin-bottom 1.5rem
    text-align center

  .hexo-encrypt-input
    display flex
    gap 0.5rem
    max-width 400px
    margin 0 auto

    .hexo-encrypt-password
      flex 1
      padding 0.6rem 1rem
      border 1px solid $color-border
      border-radius 6px
      background: rgba(255, 255, 255, 0.05)
      color $color-text
      font-size 0.9rem
      outline none

      &:focus
        border-color $color-theme

    .hexo-encrypt-submit
      padding 0.6rem 1rem
      border none
      border-radius 6px
      background $color-theme
      color white
      font-size 1rem
      cursor pointer
      transition opacity 0.2s

      &:hover
        opacity 0.85

  .hexo-encrypt-data
    display none
