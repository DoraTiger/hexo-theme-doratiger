// 重定向页面样式
.redirect
  display flex
  justify-content center
  align-items center
  min-height calc(100vh - 6rem)
  padding 2rem

  &-content
    max-width 600px
    width 100%
    padding 2.5rem
    border-radius 12px
    border 1px solid $color-border
    background $color-content-background

    &-tips
      display flex
      align-items center
      gap 0.75rem
      margin-bottom 1.5rem
      padding 1rem
      border-radius 8px
      background rgba(255, 152, 0, 0.1)
      border 1px solid rgba(255, 152, 0, 0.3)
      color rgba(255, 152, 0, 1)
      font-size 0.9rem

      &::before
        content "⚠"
        font-size 1.5rem

    &-url
      margin-bottom 2rem
      font-size 0.95rem
      line-height 1.6
      color $color-text

      #redirect-link
        display block
        margin-top 0.5rem
        padding 0.75rem 1rem
        border-radius 6px
        background rgba(128, 128, 128, 0.1)
        border 1px solid $color-border
        word-break break-all
        color $color-sub-theme
        font-size 0.85rem

  &-button
    width 100%
    padding 0.75rem
    border none
    border-radius 8px
    background $color-theme
    color white
    font-size 1rem
    font-weight 500
    cursor pointer
    transition all 0.2s

    &:hover
      opacity 0.85
      transform translateY(-1px)

// 外部链接标记
a.external-link
  &::after
    content " ↗"
    font-size 0.8em
    opacity 0.6
